# ShopeePay SDK environment variables.
#
# The SDK itself reads NOTHING from the environment. These names are the
# convention used by callers — wire them into `new Config(...)` yourself, or
# let the (future) Laravel companion package do it for you.

# Credentials issued by ShopeePay at merchant onboarding.
SHOPEEPAY_CLIENT_ID=
SHOPEEPAY_SECRET_KEY=

# Merchant identifiers. CWS = ShopeePay's product name for this integration.
# STORE_ID is optional and only used by multi-outlet merchants — pass null
# when single-store.
SHOPEEPAY_SUBS_MERCHANT_ID=
SHOPEEPAY_SUBS_STORE_ID=

# Toggle. "true" → Environment::PRODUCTION, anything else → SANDBOX.
SHOPEEPAY_IS_PRODUCTION=false

# PEM-encoded keys. Paste the full -----BEGIN ... ----- block, NOT a file path.
# In docker/k8s/secret-manager flows this avoids ever materialising a key file
# on disk.
SHOPEEPAY_PRIVATE_KEY=
SHOPEEPAY_PUBLIC_KEY=

# Where ShopeePay POSTs webhook notifications. Used by your webhook router;
# the SDK only needs the path component (callbackPath) when verifying.
SHOPEEPAY_CALLBACK_URL=

# Verbose request/response logging. The SDK scrubs accessToken, X-SIGNATURE,
# mobileNumber, accountToken, and PEM strings before they reach the logger,
# but you should still keep this "false" outside of debugging.
SHOPEEPAY_LOG=false
