{
    "name": "rrq/shopeepay-php",
    "description": "Unofficial PHP SDK for ShopeePay (SNAP BI) — typed DTOs, framework-agnostic, four flows: Account Linking, Link & Pay, Subscription, Auth & Capture.",
    "type": "library",
    "license": "MIT",
    "keywords": ["shopeepay", "snap-bi", "payment", "indonesia", "sdk", "psr-18"],
    "homepage": "https://github.com/rrq/shopeepay-php",
    "authors": [
        {
            "name": "Richard William",
            "email": "richard.william@teamrrq.com"
        }
    ],
    "require": {
        "php": "^8.1",
        "ext-openssl": "*",
        "ext-json": "*",
        "ext-hash": "*",
        "psr/http-client": "^1.0",
        "psr/http-factory": "^1.0",
        "psr/http-message": "^1.1 || ^2.0",
        "psr/simple-cache": "^1.0 || ^2.0 || ^3.0",
        "psr/log": "^1.0 || ^2.0 || ^3.0"
    },
    "require-dev": {
        "nyholm/psr7": "^1.8",
        "php-http/discovery": "^1.19",
        "php-http/mock-client": "^1.6",
        "phpstan/phpstan": "^1.11",
        "phpunit/phpunit": "^10.5",
        "symfony/cache": "^6.4 || ^7.0",
        "symfony/http-client": "^6.4 || ^7.0"
    },
    "autoload": {
        "psr-4": {
            "ShopeePay\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "ShopeePay\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "phpunit --testsuite Unit",
        "test:integration": "phpunit --testsuite Integration",
        "phpstan": "phpstan analyse --memory-limit=512M"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "php-http/discovery": true,
            "cweagans/composer-patches": false
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
